{
  "name": "monapplivoiture",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "start:dev:tunnel": "expo start --dev-client --tunnel",
    "start:dev:lan": "expo start --dev-client --lan",
    "start:dev:usb": "adb reverse tcp:8081 tcp:8081 && expo start --dev-client --localhost",
    "adb:devices": "adb devices",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "eas:build:dev": "npx eas-cli build --profile development",
    "eas:build:dev:android": "npx eas-cli build --profile development --platform android",
    "eas:build:dev:ios": "npx eas-cli build --profile development --platform ios",
    "eas:build:preview": "npx eas-cli build --profile preview",
    "eas:build:preview:android": "npx eas-cli build --profile preview --platform android",
    "eas:build:preview:ios": "npx eas-cli build --profile preview --platform ios",
    "eas:env:list": "npx eas-cli env:list",
    "android:release:local": "expo run:android --variant release"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
